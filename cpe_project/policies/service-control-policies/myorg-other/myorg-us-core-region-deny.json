{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "RegionDenyUs",
        "Effect": "Deny",
        "NotAction": [
          "a4b:*",
          "acm:*",
          "aws-marketplace-management:*",
          "aws-marketplace:*",
          "aws-portal:*",
          "budgets:*",
          "ce:*",
          "chime:*",
          "cloudfront:*",
          "config:*",
          "cur:*",
          "directconnect:*",
          "ec2:DescribeRegions",
          "ec2:DescribeTransitGateways",
          "ec2:DescribeVpnGateways",
          "ec2:*",
          "fms:*",
          "globalaccelerator:*",
          "health:*",
          "iam:*",
          "importexport:*",
          "kms:*",
          "lambda:*",
          "mobileanalytics:*",
          "networkmanager:*",
          "organizations:*",
          "pricing:*",
          "route53-recovery-control-config:*",
          "route53-recovery-readiness:*",
          "route53-recovery-cluster:*",
          "route53:*",
          "route53domains:*",
          "s3:GetBucketPublicAccessBlock",
          "s3:ListAllMyBuckets",
          "s3:GetBucketLocation",
          "shield:*",
          "sts:*",
          "support:*",
          "trustedadvisor:*",
          "waf-regional:*",
          "waf:*",
          "wafv2:*",
          "access-analyzer:*"
        ],
        "Resource": "*",
        "Condition": {
          "StringNotEquals": {
            "aws:RequestedRegion": [
              "us-west-2",
              "us-east-1",
              "ap-southeast-1",
              "eu-west-2",
              "us-east-2",
              "ap-east-1"
            ]
          },
          "ArnNotLike": {
            "aws:PrincipalARN": [
              "arn:aws:iam::*:role/Role2AllowedToBypassThisSCP",
              "arn:aws:iam::*:role/OrganizationAccountAccessRole",
              "arn:aws:iam::*:role/AWSControlTowerExecution"
            ]
          }
        }
      }
    ]
  }